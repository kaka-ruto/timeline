---
import { githubConfig, nowStatus, profile } from "../data/site";
---

<aside class="hidden h-screen overflow-y-auto bg-black p-5 xl:block">
  <section class="rounded-2xl border border-zinc-800 bg-zinc-950 p-4">
    <h3 class="text-lg font-semibold text-zinc-100">Now</h3>
    <ul class="mt-3 space-y-2 text-sm text-zinc-300">
      <li>{nowStatus.focus}</li>
      <li>{nowStatus.shipping}</li>
      <li>{nowStatus.availability}</li>
    </ul>
  </section>

  <section class="mt-4 rounded-2xl border border-zinc-800 bg-zinc-950 p-4">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-semibold text-zinc-100">GitHub Activity</h3>
      <a class="text-xs text-sky-400" href={profile.github} target="_blank" rel="noreferrer">Open</a>
    </div>
    <p id="private-activity-summary" class="mt-2 text-xs text-zinc-500">Preparing activity snapshot...</p>
    <ul id="github-events" class="mt-3 space-y-2 text-sm text-zinc-300">
      <li class="text-zinc-500">Loading latest activity...</li>
    </ul>
  </section>

  <script is:inline define:vars={{ username: githubConfig.username, limit: githubConfig.eventsLimit }}>
    const list = document.getElementById("github-events");
    const privateSummary = document.getElementById("private-activity-summary");
    const endpoint = `/api/github-activity?username=${encodeURIComponent(username)}&limit=${limit}`;

    const toLabel = (event) => {
      if (event.type === "PushEvent") {
        return `Pushed ${event.commitCount ?? 0} commit(s) to ${event.repo}`;
      }
      if (event.type === "PullRequestEvent") {
        return `${event.action} a pull request in ${event.repo}`;
      }
      if (event.type === "IssuesEvent") {
        return `${event.action} an issue in ${event.repo}`;
      }

      return `${event.type.replace("Event", "")} on ${event.repo}`;
    };

    const toDate = (value) =>
      new Intl.DateTimeFormat("en", { month: "short", day: "numeric" }).format(new Date(value));

    const renderEvent = (event) => {
      const item = document.createElement("li");
      item.className = "rounded-xl border border-zinc-800 p-2";

      const titleLink = document.createElement("a");
      titleLink.className = "hover:text-zinc-100";
      titleLink.textContent = toLabel(event);
      if (event.url) {
        titleLink.href = event.url;
        titleLink.target = "_blank";
        titleLink.rel = "noreferrer";
      }

      const date = document.createElement("p");
      date.className = "mt-1 text-xs text-zinc-500";
      date.textContent = toDate(event.createdAt);

      item.append(titleLink, date);
      return item;
    };

    const renderPrivateSummary = (summary) => {
      if (!privateSummary) return;
      const total = Number(summary?.total ?? 0);
      if (!total) {
        privateSummary.textContent = "Private activity is hidden by default.";
        return;
      }

      const byType = summary?.byType ?? {};
      const pieces = Object.entries(byType)
        .slice(0, 3)
        .map(([type, count]) => `${count} ${type.toLowerCase()}`);

      privateSummary.textContent = `Private work in the last refresh window: ${total} event(s) (${pieces.join(", ")}).`;
    };

    fetch(endpoint)
      .then((response) => response.ok ? response.json() : Promise.reject())
      .then((payload) => {
        const events = payload?.events ?? [];
        renderPrivateSummary(payload?.privateSummary);

        if (!Array.isArray(events) || events.length === 0) {
          list.innerHTML = '<li class="text-zinc-500">No recent public activity found.</li>';
          return;
        }

        list.replaceChildren(...events.slice(0, limit).map(renderEvent));
      })
      .catch(() => {
        if (privateSummary) {
          privateSummary.textContent = "Private activity summary is currently unavailable.";
        }
        list.innerHTML = '<li class="text-zinc-500">Unable to fetch GitHub activity right now.</li>';
      });
  </script>
</aside>
